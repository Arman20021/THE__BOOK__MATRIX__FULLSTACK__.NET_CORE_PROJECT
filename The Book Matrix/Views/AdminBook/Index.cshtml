@model List<BLL.DTOs.BookDto>

@{
    ViewData["Title"] = "Manage Books";
}

<div class="container mt-4">
    <h2>Manage Books</h2>

    <a asp-controller="AdminBook" asp-action="Create" class="btn btn-primary mb-3">
        Add New Book
    </a>

    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>Image</th>
                <th>Title</th>
                <th>Category</th>
                <th>Author</th>
                <th>Price</th>
                <th>Quantity</th>
                <th>Active</th>
                <th>Action</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var book in Model)
            {
                <tr>
                    <td>
                        @if (!string.IsNullOrEmpty(book.ImagePath))
                        {
                            <img src="@book.ImagePath" width="60" height="80" />
                        }
                    </td>
                    <td>@book.Title</td>
                    <td>@book.CategoryName</td>
                    <td>@book.AuthorName</td>
                    <td>@book.Price</td>
                    <td>@book.Quantity</td>
                    <td>@book.IsActive</td>
                    <td>
                        <a asp-controller="AdminBook" asp-action="Edit" asp-route-id="@book.BookId" class="btn btn-warning btn-sm">
                            Edit
                        </a>

                        <a asp-controller="AdminBook" asp-action="Delete" asp-route-id="@book.BookId" class="btn btn-danger btn-sm"
                           onclick="return confirm('Are you sure you want to delete this book?');">
                            Delete
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>