@model BLL.DTOs.CartDto

@{
    ViewData["Title"] = "My Cart";
}
 

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>My Cart</h2>

        <div>
            <a asp-controller="Home" asp-action="Index" class="btn btn-secondary me-2">
                Continue Shopping
            </a>

            <a asp-controller="Auth" asp-action="Logout" class="btn btn-danger">
                Logout
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">
            @TempData["SuccessMessage"]
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">
            @TempData["ErrorMessage"]
        </div>
    }

    @if (Model.Items.Count == 0)
    {
        <div class="alert alert-info">
            Your cart is empty.
        </div>
    }
    else
    {
        <table class="table table-bordered table-striped">
            <thead>
                <tr>
                    <th>Image</th>
                    <th>Book</th>
                    <th>Unit Price</th>
                    <th>Quantity</th>
                    <th>Line Total</th>
                    <th>Action</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>
                            @if (!string.IsNullOrEmpty(item.ImagePath))
                            {
                                <img src="@item.ImagePath" width="60" height="80" />
                            }
                        </td>

                        <td>@item.Title</td>

                        <td>@item.UnitPrice</td>

                        <td>
                            <form asp-controller="Cart" asp-action="UpdateQuantity" method="post" class="d-flex">
                                @Html.AntiForgeryToken()

                                <input type="hidden" name="cartItemId" value="@item.CartItemId" />

                                <input type="number"
                                       name="quantity"
                                       value="@item.Quantity"
                                       min="1"
                                       class="form-control me-2"
                                       style="width:90px;" />

                                <button type="submit" class="btn btn-success btn-sm">
                                    Update
                                </button>
                            </form>
                        </td>

                        <td>@item.LineTotal</td>

                        <td>
                            <a asp-controller="Cart" asp-action="Remove" asp-route-id="@item.CartItemId"
                               class="btn btn-danger btn-sm"
                               onclick="return confirm('Remove this item?');">
                                Remove
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <h4 class="text-end">
            Grand Total: @Model.GrandTotal
        </h4>
    <form asp-controller="Payment" asp-action="PayNow" method="post" class="text-end mt-3">
        @Html.AntiForgeryToken()

        <button type="submit" class="btn btn-primary btn-lg">
            Pay Now
        </button>
    </form>
    }
</div>